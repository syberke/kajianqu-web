# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Prisma / application database
# Use the pooled URL at runtime and a direct URL for Prisma Migrate.
DATABASE_URL=
DIRECT_URL=

# Gemini server key. Never expose this with NEXT_PUBLIC_.
GEMINI_API_KEY=

# Optional Quran Foundation Content API base URL.
QURAN_API_BASE_URL=https://api.quran.com/api/v4
