# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Prisma / application database
# Use the pooled URL at runtime and a direct URL for Prisma Migrate.
DATABASE_URL=
DIRECT_URL=

# Gemini server key. Never expose this with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_ANALYSIS_MODEL=gemini-2.5-flash
# Optional external provider. The current Quran flows work without this key.
QURANI_AI_API_KEY=

# Optional Quran Foundation Content API configuration.
QURAN_API_BASE_URL=https://api.quran.com/api/v4
QURAN_FALLBACK_API_BASE_URL=https://api.alquran.cloud/v1
# Ayah-by-ayah recitation ID for Belajar Al-Qur'an reference playback.
QURAN_RECITATION_ID=1

# Public contact links
NEXT_PUBLIC_WHATSAPP_NUMBER=6282262170018
NEXT_PUBLIC_WHATSAPP_URL=https://wa.me/6282262170018
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/kajian_qu/
